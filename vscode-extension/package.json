{
  "name": "pythonmentor",
  "displayName": "PythonMentor - Socratic Python Tutor",
  "description": "Personalized Python learning assistant with Socratic teaching method",
  "version": "0.1.7",
  "publisher": "Eddie-58-cgw",
  "author": "Eddie",
  "license": "MIT",
  "icon": "images/icon.png",
  "keywords": ["python", "education", "tutor", "socratic", "learning", "AI"],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Education", "Other"],
  "activationEvents": [
    "onView:python-mentor.chat",
    "onCommand:python-mentor.openChat",
    "onCommand:python-mentor.diagnoseError",
    "onCommand:python-mentor.startBackend",
    "onCommand:python-mentor.stopBackend",
    "onCommand:python-mentor.configureApiKeys",
    "onCommand:python-mentor.reconfigure"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "python-mentor",
          "title": "PythonMentor",
          "icon": "media/icon.png"
        }
      ]
    },
    "views": {
      "python-mentor": [
        {
          "type": "webview",
          "id": "python-mentor.chat",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "python-mentor.openChat",
        "title": "PythonMentor: Open Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "python-mentor.diagnoseError",
        "title": "PythonMentor: Diagnose Error",
        "icon": "$(warning)"
      },
      {
        "command": "python-mentor.startBackend",
        "title": "PythonMentor: Start Backend Server",
        "icon": "$(play)"
      },
      {
        "command": "python-mentor.stopBackend",
        "title": "PythonMentor: Stop Backend Server",
        "icon": "$(stop)"
      },
      {
        "command": "python-mentor.configureApiKeys",
        "title": "PythonMentor: Configure API Keys",
        "icon": "$(settings-gear)"
      },
      {
        "command": "python-mentor.reconfigure",
        "title": "PythonMentor: Re-run Setup Wizard",
        "icon": "$(settings-gear)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "python-mentor.diagnoseError",
          "when": "editorHasSelection",
          "group": "python-mentor"
        }
      ]
    },
    "configuration": {
      "title": "PythonMentor",
      "properties": {
        "python-mentor.backendUrl": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "Backend service URL / Python 后端服务地址"
        },
        "python-mentor.studentId": {
          "type": "string",
          "default": "default",
          "description": "Student ID for profile tracking / 学生 ID，用于区分不同学生的学习档案"
        },
        "python-mentor.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Python interpreter path (auto-detect if empty) / Python 解释器路径（留空则自动检测）"
        },
        "python-mentor.llmBackend": {
          "type": "string",
          "enum": ["ollama", "claude", "openai"],
          "default": "ollama",
          "description": "LLM backend provider / LLM 后端选择"
        },
        "python-mentor.claudeApiKey": {
          "type": "string",
          "default": "",
          "description": "Claude API Key (Anthropic-compatible) / Claude API 密钥"
        },
        "python-mentor.claudeBaseUrl": {
          "type": "string",
          "default": "",
          "description": "Anthropic-compatible API base URL (empty = official) / Anthropic 兼容 API 地址（留空使用官方）"
        },
        "python-mentor.claudeModel": {
          "type": "string",
          "default": "claude-sonnet-4-20250514",
          "description": "Claude model name / Claude 模型名"
        },
        "python-mentor.openaiApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API Key (or OpenAI-compatible) / OpenAI API 密钥"
        },
        "python-mentor.openaiBaseUrl": {
          "type": "string",
          "default": "",
          "description": "OpenAI-compatible base URL (DeepSeek, etc. Empty = official) / OpenAI 兼容 API 地址"
        },
        "python-mentor.openaiModel": {
          "type": "string",
          "default": "gpt-4o",
          "description": "OpenAI model name (e.g. gpt-4o, deepseek-chat) / OpenAI 模型名"
        },
        "python-mentor.ollamaUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama service URL / Ollama 服务地址"
        },
        "python-mentor.ollamaModel": {
          "type": "string",
          "default": "qwen2.5:14b",
          "description": "Ollama model name / Ollama 模型名"
        },
        "python-mentor.embeddingApiKey": {
          "type": "string",
          "default": "",
          "description": "Embedding API Key (required for RAG) / 嵌入 API 密钥（RAG 必需）"
        },
        "python-mentor.embeddingModel": {
          "type": "string",
          "default": "text-embedding-v4",
          "description": "Embedding model name / 嵌入模型名"
        },
        "python-mentor.embeddingApiUrl": {
          "type": "string",
          "default": "https://dashscope.aliyuncs.com/compatible-mode/v1",
          "description": "Embedding API base URL / 嵌入 API 地址"
        },
        "python-mentor.maxTokens": {
          "type": "integer",
          "default": 2048,
          "minimum": 256,
          "maximum": 16384,
          "description": "Max tokens per LLM response / 单次回复最大 token 数"
        },
        "python-mentor.temperature": {
          "type": "number",
          "default": 0.7,
          "minimum": 0.0,
          "maximum": 2.0,
          "description": "LLM temperature: lower = more deterministic / 温度参数：越低越确定"
        },
        "python-mentor.topP": {
          "type": "number",
          "default": 1.0,
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Top-P sampling (1.0 = disabled) / Top-P 采样参数"
        },
        "python-mentor.contextWindow": {
          "type": "integer",
          "default": 40,
          "minimum": 5,
          "maximum": 100,
          "description": "Recent conversation turns sent to LLM / 发送给 LLM 的最近对话轮数"
        }
      }
    }
  },
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "watch": "webpack --watch --mode development",
    "copy-deps": "node scripts/copy-backend.js",
    "clean-deps": "node scripts/clean-backend.js",
    "package": "npm run build && npm run copy-deps && vsce package --allow-missing-repository && npm run clean-deps",
    "publish": "npm run build && npm run copy-deps && vsce publish --allow-missing-repository && npm run clean-deps"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0",
    "ts-loader": "^9.5.0",
    "@vscode/vsce": "^2.0.0"
  }
}
