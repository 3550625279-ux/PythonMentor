# PythonMentor Backend Configuration
# This file is auto-generated by the VS Code extension from its settings.
# Only edit manually if running the backend standalone.

# LLM Backend: "claude" | "openai" | "ollama"
LLM_BACKEND=ollama

# Claude / Anthropic-compatible (required if LLM_BACKEND=claude)
CLAUDE_API_KEY=
CLAUDE_BASE_URL=
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI / OpenAI-compatible (required if LLM_BACKEND=openai)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o

# Ollama (requires Ollama running locally)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# Server
HOST=127.0.0.1
PORT=8000

# RAG Knowledge Base
CHROMA_DB_PATH=./chroma_db
DISTANCE_THRESHOLD=0.7
RAG_TOP_K=3

# Embedding API (required for RAG knowledge retrieval)
EMBEDDING_API_KEY=
EMBEDDING_API_MODEL=text-embedding-v4
EMBEDDING_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_DIMENSIONS=1024

# Critique Model (optional, reuses main LLM if CRITIQUE_MODEL is empty)
CRITIQUE_ENABLED=false
CRITIQUE_MODEL=

# LLM Parameters
MAX_TOKENS=2048
TEMPERATURE=0.7
TOP_P=1.0
CONTEXT_WINDOW=40
